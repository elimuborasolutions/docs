{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Elimu Bora ERP Help Center",
  "description": "Help center for Elimu Bora ERP — a school management system for Kenyan schools running CBC and 8-4-4.",
  "colors": {
    "primary": "#800000",
    "light": "#800000",
    "dark": "#800000"
  },
  "favicon": "https://media.brand.dev/28107f06-65a0-45ce-9937-4bc6a00d197b.svg",
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://elimuboraerp.com/contact/"
    },
    "links": [{ "type": "button", "label": "Login", "href": "https://elimuboraerp.com/login" }]
  },
  "navigation": {
    "global": {
      "anchors": [
        { "anchor": "Pricing", "href": "https://elimuboraerp.com/pricing/", "icon": "tag" },
        { "anchor": "Book a Demo", "href": "https://elimuboraerp.com/contact/", "icon": "calendar-check" },
        { "anchor": "Blog & Resources", "href": "https://elimuboraerp.com/blog/", "icon": "newspaper" },
        { "anchor": "Contact Us", "href": "https://elimuboraerp.com/contact/", "icon": "mail" }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "pages": [
          "introduction",
          "quickstart",
          "modules/users",
          "modules/curriculum",
          "modules/academic-years",
          "modules/attendance",
          "modules/assessments",
          "modules/timetable",
          "modules/events",
          "modules/finance",
          "modules/inventory",
          "modules/sports",
          "modules/clubs",
          "modules/activity-log",
          "roles-permissions",
          "staff/overview",
          "guardians/overview",
          "settings/overview"
        ]
      }
    ]
  },
  "appearance": { "default": "system" },
  "background": { "decoration": "windows" },
  "logo": {
    "light": "/images/elimubora-logo-primary.png",
    "dark": "/images/elimubora-logo-white.png"
  },
  "fonts": {
    "heading": { "family": "Sora", "weight": 700 },
    "body": { "family": "DM Sans", "weight": 400 }
  },
  "footer": {
    "socials": {
      "website": "https://elimuboraerp.com/",
      "x": "https://x.com/elimuboraerp",
      "facebook": "https://www.facebook.com/elimuborasolutions",
      "instagram": "https://www.instagram.com/elimuboraerp",
      "linkedin": "https://www.linkedin.com/company/elimu-bora-solutions-co"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Pricing", "href": "https://elimuboraerp.com/pricing/" },
          { "label": "Book a Demo", "href": "https://elimuboraerp.com/contact/" }
        ]
      },
      {
        "header": "Company",
        "items": [
          { "label": "Blog & Resources", "href": "https://elimuboraerp.com/blog/" },
          { "label": "Contact Us", "href": "https://elimuboraerp.com/contact/" }
        ]
      },
      {
        "header": "Legal",
        "items": [
          { "label": "Privacy Policy", "href": "https://elimuboraerp.com/privacy/" },
          { "label": "Terms of Service", "href": "https://elimuboraerp.com/terms/" }
        ]
      },
      {
        "header": "Support",
        "items": [
          { "label": "support@elimuboraerp.com", "href": "mailto:support@elimuboraerp.com" },
          { "label": "Contact Us", "href": "https://elimuboraerp.com/contact/" }
        ]
      }
    ]
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": true
  },
  "icons": { "library": "lucide" },
  "thumbnails": {
    "background": "/images/cover.png",
    "fonts": { "family": "Sora" }
  }
}
